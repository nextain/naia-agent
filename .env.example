# new-naia-agent — environment variables (example)
# Copy to `.env` (or export in your shell) and adjust. All vars are OPTIONAL:
# the runtime has sensible defaults for every one of them.
#
# These are the variables consumed by the brain runtime entry point
# (scripts/builds/agent-stdio-entry.mjs) and the naia-memory wiring.
# CI-only / harness-internal vars (M2/M3/M4_PROJECT_ROOT, CHARTER_*, CI_PROJECT_ROOT,
# GITHUB_TOKEN, etc.) are intentionally not listed here — they belong to the
# maintainer's enforcement layer, not to running the product.

# ── Provider ────────────────────────────────────────────────────────────────
# Which LLM provider the brain uses.
#   fake        → headless deterministic provider (E2E, no LLM needed)
#   echo-system → echoes the system prompt (recall→inject pass-through tests)
#   (unset)     → config-driven resolver (lab-proxy / native / ollama)
AGENT_PROVIDER=fake

# ── Workspace / ADK ─────────────────────────────────────────────────────────
# Path to the naia-adk workspace (config + skill settings source of truth).
# Default: $HOME/naia-adk
NAIA_ADK_PATH=

# ── gRPC server ─────────────────────────────────────────────────────────────
# Address the brain's gRPC server binds to. Default: 127.0.0.1:0 (random port)
NAIA_AGENT_GRPC_ADDR=127.0.0.1:0

# Set to 1 for verbose stderr diagnostics. Default: off
NAIA_AGENT_DEBUG=

# ── Skills (UC5) ────────────────────────────────────────────────────────────
# Set to "off" to disable the built-in time/weather/memo skills. Default: on
NAIA_AGENT_SKILLS=

# Persisted memo store path. Default: $HOME/.naia-agent/memos.json
NAIA_MEMO_PATH=

# Optional Obsidian vault path for the obsidian skill. Default: unset (skill off)
NAIA_OBSIDIAN_VAULT=

# Optional external MCP tool server. Command to launch + display name.
NAIA_MCP_CMD=
NAIA_MCP_NAME=mcp

# ── Long-term memory (naia-memory) ──────────────────────────────────────────
# Set to "off" to disable memory wiring. Default: on
NAIA_AGENT_MEMORY=

# Memory store base dir.  Default: $HOME/.naia-agent/memory
NAIA_MEMORY_DIR=

# Explicit store file path. Default: <NAIA_MEMORY_DIR>/<project>/store.json
NAIA_MEMORY_STORE=

# Logical project / workspace id for memory partitioning.
# Default: derived from the ADK workspace path.
NAIA_MEMORY_PROJECT=

# Session id for this run. Default: proc-<random-uuid>
NAIA_MEMORY_SESSION=

# ── Conversation transcript ─────────────────────────────────────────────────
# Set to "off" to disable transcript logging. Default: on
NAIA_AGENT_TRANSCRIPT=

# Directory where conversation transcripts are written.
# Default: <NAIA_ADK_PATH>/conversations
NAIA_CONVERSATIONS_DIR=
