# naia-agent provider config — auto-loaded by bin/naia-agent.ts
#
# Usage:
#   1) Copy this file: cp naia-agent.env.example naia-agent.env
#   2) Fill in your keys (uncomment exactly ONE provider section)
#   3) chmod 600 naia-agent.env  (recommended)
#   4) pnpm naia-agent "your prompt"
#
# Search order: ./.env > ./naia-agent.env > ~/.naia-agent/.env (first match wins).
# process.env always wins over file values.
#
# See docs/llm-config-standard.md for full standard.

# ─────────────────────────────────────────────────────────────────────────
# Provider resolution priority (top → bottom):
# ─────────────────────────────────────────────────────────────────────────

# ── 1. Anthropic 직접 ─────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001        # optional
# ANTHROPIC_BASE_URL=https://api.anthropic.com     # optional, gateway 라우팅

# ── 2. OpenAI-compat (generic — vLLM, OpenRouter, Together, Groq, Ollama) ─
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4

# ── 3. zai/Zhipu GLM (OpenAI-compat 단축형) ────────────────────
# GLM_API_KEY=...
# GLM_MODEL=glm-4.5-flash
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4    # optional, default

# ── 4. Anthropic on Vertex AI (gcloud ADC 활성 필요) ────────────
# gcloud auth application-default login
# VERTEX_PROJECT_ID=your-gcp-project
# VERTEX_REGION=us-east5
# ANTHROPIC_MODEL=claude-haiku-4-5@20251001        # Vertex format (@ separator)

# ── (none) → mock fallback ───────────────────────────────────────
# 모든 키 비우면 mock LLM 응답 ("Hello! I'm naia-agent in mock mode")
