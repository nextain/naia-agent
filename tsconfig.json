{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": false,
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "types": [],
    "lib": [
      "ES2022",
      "DOM"
    ]
  },
  "include": [
    "src/main",
    "src/test"
  ],
  "exclude": [
    "src/test/bench-metrics.contract.test.ts",
    "src/test/bench-ensemble.contract.test.ts",
    "src/test/bench-recall-judge.contract.test.ts",
    "src/test/bench-runner.contract.test.ts",
    "src/test/bench-report.contract.test.ts",
    "src/test/bench-humanlike.contract.test.ts",
    "src/test/bench-humanlike-purity.contract.test.ts",
    "src/test/bench-humanlike-bridge.integration.test.ts"
  ]
}