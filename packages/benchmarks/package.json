{
  "name": "@nextain/agent-benchmarks",
  "version": "0.1.0",
  "description": "Compaction strategy benchmark harness — fixture replay + 5-axis metrics (task-accuracy / fact-recall / latency / cost / drift) + LLM-as-judge integration. Slice 3-XR-Compact.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": ["dist", "src"],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22"
  },
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nextain/naia-agent.git",
    "directory": "packages/benchmarks"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "bench:compact": "tsx src/runner.ts"
  },
  "dependencies": {
    "@nextain/agent-types": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "vitest": "^2.1.0"
  }
}
