{
  "name": "@nextain/agent-providers",
  "version": "0.2.0",
  "description": "LLMClient implementations: VercelClient (50+ providers via Vercel AI SDK) + Naia Lab Gateway (HTTPS / WSS).",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "default": "./dist/index.js"
    },
    "./lab-proxy": {
      "import": {
        "types": "./dist/lab-proxy.d.ts",
        "default": "./dist/lab-proxy.js"
      },
      "default": "./dist/lab-proxy.js"
    },
    "./lab-proxy-live": {
      "import": {
        "types": "./dist/lab-proxy-live.d.ts",
        "default": "./dist/lab-proxy-live.js"
      },
      "default": "./dist/lab-proxy-live.js"
    },
    "./vercel": {
      "import": {
        "types": "./dist/vercel-client.d.ts",
        "default": "./dist/vercel-client.js"
      },
      "default": "./dist/vercel-client.js"
    }
  },
  "sideEffects": false,
  "files": ["dist", "src"],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nextain/naia-agent.git",
    "directory": "packages/providers"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "build": "tsc -b",
    "rebuild": "pnpm run clean && pnpm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "@nextain/agent-types": "workspace:*"
  },
  "peerDependencies": {
    "@ai-sdk/provider": "^3.0.0",
    "ai": "^6.0.0",
    "ws": "^8.19.0"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/provider": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "ws": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@ai-sdk/anthropic": "^2.0.0",
    "@ai-sdk/google": "^3.0.0",
    "@ai-sdk/openai-compatible": "^2.0.0",
    "ai-sdk-provider-claude-code": "^3.0.0",
    "zhipu-ai-provider": "^0.3.0"
  },
  "devDependencies": {
    "@ai-sdk/anthropic": "^2.0.0",
    "@ai-sdk/provider": "^3.0.0",
    "@types/ws": "^8.18.1",
    "ai": "^6.0.0",
    "ws": "^8.19.0",
    "vitest": "^3.2.4"
  }
}
