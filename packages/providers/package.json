{
  "name": "@nextain/agent-providers",
  "version": "0.1.0",
  "description": "LLMClient implementations for major providers (Anthropic, more to come).",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "default": "./dist/index.js"
    },
    "./anthropic": {
      "import": {
        "types": "./dist/anthropic.d.ts",
        "default": "./dist/anthropic.js"
      },
      "default": "./dist/anthropic.js"
    },
    "./anthropic-vertex": {
      "import": {
        "types": "./dist/anthropic-vertex.d.ts",
        "default": "./dist/anthropic-vertex.js"
      },
      "default": "./dist/anthropic-vertex.js"
    }
  },
  "sideEffects": false,
  "files": ["dist", "src"],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nextain/naia-agent.git",
    "directory": "packages/providers"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b"
  },
  "dependencies": {
    "@nextain/agent-types": "workspace:*"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@anthropic-ai/vertex-sdk": "^0.16.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@anthropic-ai/vertex-sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@anthropic-ai/vertex-sdk": "^0.16.0"
  }
}
