{
  "name": "@nextain/agent-providers",
  "version": "0.1.0",
  "description": "LLMClient implementations for major providers (Anthropic, more to come).",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "default": "./dist/index.js"
    },
    "./anthropic": {
      "import": {
        "types": "./dist/anthropic.d.ts",
        "default": "./dist/anthropic.js"
      },
      "default": "./dist/anthropic.js"
    },
    "./anthropic-vertex": {
      "import": {
        "types": "./dist/anthropic-vertex.d.ts",
        "default": "./dist/anthropic-vertex.js"
      },
      "default": "./dist/anthropic-vertex.js"
    },
    "./openai-compat": {
      "import": {
        "types": "./dist/openai-compat.d.ts",
        "default": "./dist/openai-compat.js"
      },
      "default": "./dist/openai-compat.js"
    },
    "./claude-cli": {
      "import": {
        "types": "./dist/claude-cli.d.ts",
        "default": "./dist/claude-cli.js"
      },
      "default": "./dist/claude-cli.js"
    },
    "./lab-proxy": {
      "import": {
        "types": "./dist/lab-proxy.d.ts",
        "default": "./dist/lab-proxy.js"
      },
      "default": "./dist/lab-proxy.js"
    },
    "./gemini": {
      "import": {
        "types": "./dist/gemini.d.ts",
        "default": "./dist/gemini.js"
      },
      "default": "./dist/gemini.js"
    },
    "./lab-proxy-live": {
      "import": {
        "types": "./dist/lab-proxy-live.d.ts",
        "default": "./dist/lab-proxy-live.js"
      },
      "default": "./dist/lab-proxy-live.js"
    }
  },
  "sideEffects": false,
  "files": ["dist", "src"],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nextain/naia-agent.git",
    "directory": "packages/providers"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run"
  },
  "dependencies": {
    "@nextain/agent-types": "workspace:*"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@anthropic-ai/vertex-sdk": "^0.16.0",
    "@google/genai": "^1.42.0",
    "ws": "^8.19.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@anthropic-ai/vertex-sdk": {
      "optional": true
    },
    "@google/genai": {
      "optional": true
    },
    "ws": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@anthropic-ai/vertex-sdk": "^0.16.0",
    "@google/genai": "^1.42.0",
    "@types/ws": "^8.18.1",
    "ws": "^8.19.0",
    "vitest": "^3.2.4"
  }
}
