{
  "name": "@nextain/agent-adapter-opencode-cli",
  "version": "0.1.0",
  "description": "opencode CLI SubAgentAdapter — wraps `opencode run --format json` for Phase 1. ACP integration is Phase 2.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": ["dist", "src"],
  "license": "Apache-2.0",
  "engines": { "node": ">=22" },
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run"
  },
  "dependencies": {
    "@nextain/agent-types": "workspace:*",
    "@nextain/agent-observability": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  }
}
