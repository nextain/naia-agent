{
  "name": "naia-agent",
  "version": "0.0.0",
  "private": true,
  "description": "AI coding agent runtime — loop, tools, compaction, memory, LLM routing",
  "type": "module",
  "license": "Apache-2.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "test": "pnpm -r --if-present test",
    "check:harness-sync": "bash scripts/sync-harness-mirrors.sh --check",
    "sync:harness": "bash scripts/sync-harness-mirrors.sh",
    "naia-agent": "tsx bin/naia-agent.ts",
    "smoke:vercel-anthropic": "tsx scripts/smoke-vercel-anthropic.ts",
    "smoke:agent": "tsx examples/minimal-host.ts",
    "smoke:compaction": "tsx examples/compaction-host.ts",
    "smoke:naia-memory": "tsx examples/naia-memory-host.ts",
    "smoke:tool-error-halt": "tsx examples/tool-error-halt.ts",
    "smoke:skill-loader": "tsx examples/skill-loader-host.ts",
    "smoke:skill-tool": "tsx examples/skill-tool-host.ts",
    "smoke:composite": "tsx examples/composite-host.ts",
    "smoke:bash-skill": "tsx examples/bash-skill-host.ts",
    "smoke:opencode": "tsx scripts/smoke-opencode.ts"
  },
  "devDependencies": {
    "@nextain/agent-adapter-opencode-acp": "workspace:*",
    "@nextain/agent-adapter-opencode-cli": "workspace:*",
    "@nextain/agent-adapter-shell": "workspace:*",
    "@nextain/agent-cli-app": "workspace:*",
    "@nextain/agent-core": "workspace:*",
    "@nextain/agent-observability": "workspace:*",
    "@nextain/agent-providers": "workspace:*",
    "@nextain/agent-runtime": "workspace:*",
    "@nextain/agent-types": "workspace:*",
    "@nextain/agent-verification": "workspace:*",
    "@nextain/agent-workspace": "workspace:*",
    "@nextain/naia-memory": "file:../alpha-memory",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.0",
    "@ai-sdk/google": "^3.0.64",
    "@ai-sdk/openai-compatible": "^2.0.41",
    "ai": "^6.0.0",
    "ai-sdk-provider-claude-code": "^3.4.4",
    "zhipu-ai-provider": "^0.3.0"
  }
}
