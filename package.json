{
  "name": "@nextain/naia-agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "naia-agent — naia 생태계 뇌 런타임 + sub-agent 오케스트레이터(헥사고날)",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "bin": {
    "naia-agent": "bin/naia-agent.mjs",
    "naia-agent-chat": "bin/naia-agent-chat.mjs",
    "naia-agent-run": "bin/naia-agent-run.mjs"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node scripts/builds/agent-stdio-entry.mjs",
    "supervise": "node bin/naia-agent-run.mjs",
    "chat": "node bin/naia-agent-chat.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:report": "vitest run --reporter=verbose"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.179",
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.1",
    "@naia/kb-compiler": "file:../../naia-kb-compiler",
    "@nextain/naia-memory": "file:../../naia-memory",
    "js-yaml": "^4.2.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
